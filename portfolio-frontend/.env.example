# Copy to .env.local and fill in values

# Public site URL (used for OpenRouter referer header in production)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# URL of the Strapi CMS (required in production — do not leave as localhost)
NEXT_PUBLIC_STRAPI_URL=http://localhost:1337

# OpenRouter API key for the firmware assistant — https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Optional: override the chat model (default: google/gemini-2.0-flash-exp:free)
# OPENROUTER_MODEL=
