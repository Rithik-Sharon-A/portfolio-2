# Copy to .env.local and fill in values

# URL of the Strapi CMS (default local dev)
NEXT_PUBLIC_STRAPI_URL=http://localhost:1337

# OpenRouter API key for the "Ask Rithik" chatbot — free key at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Optional: override the chat model (default: google/gemini-2.0-flash-exp:free)
# OPENROUTER_MODEL=
