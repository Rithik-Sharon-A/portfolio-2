{
  "name": "io-manager",
  "version": "1.0.0",
  "description": "Import/Export manager for Strapi v5",
  "strapi": {
    "name": "io-manager",
    "displayName": "IO Manager",
    "description": "Import and export content as JSON",
    "kind": "plugin"
  },
  "exports": {
    "./strapi-admin": {
      "source": "./admin/src/index.js",
      "import": "./admin/src/index.js",
      "require": "./admin/src/index.js",
      "default": "./admin/src/index.js"
    },
    "./strapi-server": {
      "source": "./strapi-server.js",
      "import": "./strapi-server.js",
      "require": "./strapi-server.js",
      "default": "./strapi-server.js"
    }
  }
}
