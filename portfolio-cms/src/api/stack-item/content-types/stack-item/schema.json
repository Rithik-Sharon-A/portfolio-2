{
  "kind": "collectionType",
  "collectionName": "stack_items",
  "info": {
    "singularName": "stack-item",
    "pluralName": "stack-items",
    "displayName": "StackItem",
    "description": "Tech stack items with cricket roles"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "cricketRole": {
      "type": "string",
      "required": true
    },
    "iconUrl": {
      "type": "string"
    },
    "icon": {
      "allowedTypes": ["images"],
      "type": "media",
      "multiple": false
    },
    "order": {
      "type": "integer",
      "default": 1
    }
  }
}
